{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "behavioral-va-eval task",
  "type": "object",
  "required": [
    "family",
    "category",
    "domain",
    "difficulty",
    "expected_backend",
    "scoring"
  ],
  "anyOf": [
    {
      "required": [
        "id"
      ]
    },
    {
      "required": [
        "task_id"
      ]
    }
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "family": {
      "type": "string",
      "enum": [
        "spec-to-va",
        "bugfix",
        "tb-generation",
        "end-to-end"
      ]
    },
    "category": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "enum": [
        "voltage"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "expected_backend": {
      "type": "string",
      "enum": [
        "evas"
      ]
    },
    "must_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_not_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signature_requirements": {
      "type": "object",
      "properties": {
        "required_ports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_parameters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_tokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_tokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_tb_tokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_tb_tokens": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoring": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "syntax",
          "routing",
          "simulation",
          "behavior",
          "dut_compile",
          "tb_compile",
          "sim_correct"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
