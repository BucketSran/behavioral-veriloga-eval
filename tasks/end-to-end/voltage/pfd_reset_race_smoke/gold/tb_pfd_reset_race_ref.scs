    160n 0.9 \
    170n 0 \
    180n 0.9 \
    190n 0 \
    200n 0.9 \
    210n 0 \
    220n 0.9 \
    230n 0 \
    240n 0.9 \
    250n 0 \
    260n 0.9 \
    270n 0 \
    280n 0.9 \
    290n 0 \
    300n 0 \
]
Vdiv (div 0) vsource type=pwl wave=[ \
    0      0 \
    20.2n  0.9 \
    30.2n  0 \
    40.2n  0.9 \
    50.2n  0 \
    60.2n  0.9 \
    70.2n  0 \
    80.2n  0.9 \
    90.2n  0 \
    100.2n 0.9 \
    110.2n 0 \
    120.2n 0.9 \
    130.2n 0 \
    139.8n 0.9 \
