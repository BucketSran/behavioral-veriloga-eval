    4973.75n 1.8 4983.5n 0 4993.25n 1.8 5003n 0 5012.75n 1.8 5022.5n 0 \
    5032.25n 1.8 5042n 0 5051.75n 1.8 5061.5n 0 5071.25n 1.8 5081n 0 \
    5090.75n 1.8 5100.5n 0 5110.25n 1.8 5120n 0 5129.75n 1.8 5139.5n 0 \
    5149.25n 1.8 5159n 0 5168.75n 1.8 5178.5n 0 5188.25n 1.8 5198n 0 \
    5207.75n 1.8 5217.5n 0 5227.25n 1.8 5237n 0 5246.75n 1.8 5256.5n 0 \
