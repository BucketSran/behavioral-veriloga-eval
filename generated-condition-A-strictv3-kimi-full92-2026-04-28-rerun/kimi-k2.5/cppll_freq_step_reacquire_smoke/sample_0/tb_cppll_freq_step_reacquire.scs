    5383.25n 1.8 5393n 0 5402.75n 1.8 5412.5n 0 5422.25n 1.8 5432n 0 \
    5441.75n 1.8 5451.5n 0 5461.25n 1.8 5471n 0 5480.75n 1.8 5490.5n 0 \
    5500.25n 1.8 5510n 0 5519.75n 1.8 5529.5n 0 5539.25n 1.8 5549n 0 \
    5558.75n 1.8 5568.5n 0 5578.25n 1.8 5588n 0 5597.75n 1.8 5607.5n 0 \
    5617.25n 1.8 5627n 0 5636.75n 1.8 5646.5n 0 5656.25n 1.8 5666n 0 \
    5675.75n 1.8 5685.5n 0 5695.25n 1.8 5705n 0 5714.75n 1.8 5724.5n 0 \
    5734.25n 1.8 5744n 0 5753.75n 1.8 5763.5n 0 5773.25n 1.8 5783n 0 \
    5792.75n 1.8 5802.5n 0 5812.25n 1.8 5822n 0 5831.75n 1.8 5841.5n 0 \
    5851.25n 1.8 5861n 0 5870.75n 1.8 5880.5n 0 5890.25n 1.8 5900n 0 \
    5909.75n 1.8 5919.5n 0 5929.25n 1.8 5939n 0 5948.75n 1.8 5958.5n 0 \
    5968.25n 1.8 5978n 0 5987.75n 1.8 5997.5n 0]

// DUT instance
dut (VDD VSS ref_clk fb_clk dco_clk vctrl_mon lock) cppll_timer_ref

// Transient analysis
tran tran stop=6u maxstep=5n errpreset=conservative

// Save statements for required waveforms
save ref_clk
save fb_clk
save lock
save vctrl_mon
