// tb_cppll_freq_step_reacquire.scs
// Minimal EVAS-compatible testbench for CPPLL timer-based model

simulator lang=spectre

// Include Verilog-A module
ahdl_include "cppll_timer_ref.va"

// Supply voltages
VDD (VDD 0) vsource dc=1.8
VSS (VSS 0) vsource dc=0

// Reference clock: 50 MHz for first 2us, then step to ~51.28 MHz (19.5ns period)
// Using PWL to create frequency step
Vref (ref_clk 0) vsource type=pwl wave=[0 0 10n 1.8 20n 0 30n 1.8 40n 0 50n 1.8 \
    60n 0 70n 1.8 80n 0 90n 1.8 100n 0 110n 1.8 120n 0 130n 1.8 140n 0 \
    150n 1.8 160n 0 170n 1.8 180n 0 190n 1.8 200n 0 \
    210n 1.8 220n 0 230n 1.8 240n 0 250n 1.8 260n 0 270n 1.8 280n 0 \
    290n 1.8 300n 0 310n 1.8 320n 0 330n 1.8 340n 0 350n 1.8 360n 0 \
    370n 1.8 380n 0 390n 1.8 400n 0 \
    // Continue 50 MHz until 2us = 2000ns \
    // Then switch to 51.28 MHz (period = 19.5ns) \
    2000n 0 2009.75n 1.8 2019.5n 0 2029.25n 1.8 2039n 0 \
    2048.75n 1.8 2058.5n 0 2068.25n 1.8 2078n 0 2087.75n 1.8 2097.5n 0 \
    2107.25n 1.8 2117n 0 2126.75n 1.8 2136.5n 0 2146.25n 1.8 2156n 0 \
    2165.75n 1.8 2175.5n 0 2185.25n 1.8 2195n 0 2204.75n 1.8 2214.5n 0 \
    2224.25n 1.8 2234n 0 2243.75n 1.8 2253.5n 0 2263.25n 1.8 2273n 0 \
    2282.75n 1.8 2292.5n 0 2302.25n 1.8 2312n 0 2321.75n 1.8 2331.5n 0 \
    2341.25n 1.8 2351n 0 2360.75n 1.8 2370.5n 0 2380.25n 1.8 2390n 0 \
    2399.75n 1.8 2409.5n 0 2419.25n 1.8 2429n 0 2438.75n 1.8 2448.5n 0 \
    2458.25n 1.8 2468n 0 2477.75n 1.8 2487.5n 0 2497.25n 1.8 2507n 0 \
    2516.75n 1.8 2526.5n 0 2536.25n 1.8 2546n 0 2555.75n 1.8 2565.5n 0 \
    2575.25n 1.8 2585n 0 2594.75n 1.8 2604.5n 0 2614.25n 1.8 2624n 0 \
    2633.75n 1.8 2643.5n 0 2653.25n 1.8 2663n 0 2672.75n 1.8 2682.5n 0 \
    2692.25n 1.8 2702n 0 2711.75n 1.8 2721.5n 0 2731.25n 1.8 2741n 0 \
    2750.75n 1.8 2760.5n 0 2770.25n 1.8 2780n 0 2789.75n 1.8 2799.5n 0 \
    2809.25n 1.8 2819n 0 2828.75n 1.8 2838.5n 0 2848.25n 1.8 2858n 0 \
    2867.75n 1.8 2877.5n 0 2887.25n 1.8 2897n 0 2906.75n 1.8 2916.5n 0 \
    2926.25n 1.8 2936n 0 2945.75n 1.8 2955.5n 0 2965.25n 1.8 2975n 0 \
    2984.75n 1.8 2994.5n 0 3004.25n 1.8 3014n 0 3023.75n 1.8 3033.5n 0 \
    3043.25n 1.8 3053n 0 3062.75n 1.8 3072.5n 0 3082.25n 1.8 3092n 0 \
    3101.75n 1.8 3111.5n 0 3121.25n 1.8 3131n 0 3140.75n 1.8 3150.5n 0 \
