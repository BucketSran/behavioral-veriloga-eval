    3394.25n 1.8 3404n 0 3413.75n 1.8 3423.5n 0 3433.25n 1.8 3443n 0 \
    3452.75n 1.8 3462.5n 0 3472.25n 1.8 3482n 0 3491.75n 1.8 3501.5n 0 \
    3511.25n 1.8 3521n 0 3530.75n 1.8 3540.5n 0 3550.25n 1.8 3560n 0 \
