// DUT instance
bbpd_data_edge_alignment_ref dut (
    .vdd            vdd
    .vss            vss
    .clk            clk
    .data           data
    .up             up
    .dn             dn
    .retimed_data   retimed_data
)

// Transient analysis
tran tran stop=170n maxstep=0.1n

// Save statements for required signals
save clk
save data
save up
save dn
