// Spectre testbench for bbpd_data_edge_alignment_ref

// Include the Verilog-A model
ahdl_include "bbpd_data_edge_alignment_ref.va"

// Supply voltages
vsource vdd (vdd 0) vdc=1.0
vsource vss (vss 0) vdc=0.0

// Clock source - 500MHz clock (2ns period)
vsource vclk (clk 0) vdc=0.0 vpulse=(0 1.0 0 0.1n 0.1n 0.9n 2.0n)

// Data source - pattern with intentional phase variations
// Create data edges at various alignments relative to clock
// Using vpulse with different delays to create phase sweep

// Data pattern: start aligned, then lead, then lag, then lead, etc.
// Period: 4ns (half clock rate for NRZ-like data)
// Phase modulation: 0, +0.3n (lead), -0.3n (lag), +0.5n, -0.5n, etc.

// Create data with phase modulation using piecewise linear
vsource vdata (data 0) vdc=0.0 \
    vpwl=[ \
        0n      0.0 \
        0.5n    0.0 \
        0.6n    1.0 \
        2.0n    1.0 \
